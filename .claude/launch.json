{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Node API (dev watch)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--watch", "server/index.js"],
      "port": 3000
    },
    {
      "name": "Node API (production)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server/index.js"],
      "port": 3000
    },
    {
      "name": "Static frontend (index.html)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-s", ".", "-l", "5173"],
      "port": 5173
    }
  ]
}
